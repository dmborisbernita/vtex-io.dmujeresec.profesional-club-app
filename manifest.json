{
  "name": "club-profesional",
  "vendor": "dmujeresec",
  "version": "0.3.2",
  "title": "Club Profesional App",
  "description": "Reference app for VTEX IO Services",
  "mustUpdateAt": "2018-01-04",
  "categories": [],
  "dependencies": {
    "vtex.store": "2.x",
    "vtex.css-handles": "1.x",
    "vtex.rich-text": "0.x",
    "vtex.store-components": "3.x",
    "vtex.flex-layout": "0.x"
  },
  "builders": {
    "node": "7.x",
    "docs": "0.x",
    "react": "3.x",
    "store": "0.x",
    "styles": "2.x"
  },
  "credentialType": "absolute",
  "settingsSchema": {
    "title": "Club Profesional",
    "type": "object",
    "properties": {
      "recaptchaSiteKey": {
        "title": "reCAPTCHA v3 - Site key (pública)",
        "type": "string"
      },
      "recaptchaSecretKey": {
        "title": "reCAPTCHA v3 - Secret key (privada)",
        "type": "string"
      },
      "registrationsApiToken": {
        "title": "Registrations API - Token (privado)",
        "type": "string"
      }
    }
  },
  "policies": [
    {
      "name": "outbound-access",
      "attrs": {
        "host": "www.google.com",
        "path": "/recaptcha/api/siteverify*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "{{account}}.myvtex.com",
        "path": "/api/dataentities/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.dmujeres.ec",
        "path": "/v2/registrations/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.clubprofesional.com",
        "path": "/registrations*"
      }
    },
    {
      "name": "ADMIN_DS"
    }
  ],
  "billingOptions": {
    "termsURL": "",
    "support": {
      "url": ""
    },
    "free": true,
    "type": "free"
  },
  "$schema": "https://raw.githubusercontent.com/vtex/node-vtex-api/master/gen/manifest.schema"
}
